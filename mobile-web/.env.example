# BoxDrop Mobile-Web Environment Variables
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace placeholder values with your actual API keys
# 3. Load environment: export $(cat .env | xargs)
# 4. Start Expo: npm start
#
# Note: Changing native config (GOOGLE_MAPS_API_KEY) requires rebuild:
# npm run android -- --build-locally
#
# DO NOT COMMIT THIS FILE - .env is in .gitignore
# Keep this .env.example file in git with placeholder values for documentation

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL - used for all HTTP requests
EXPO_PUBLIC_API_URL=http://localhost:8080

# ============================================
# GOOGLE MAPS (Android and Web)
# ============================================
# Required for map features on Android and web
# Sign up: https://console.cloud.google.com/apis/credentials
# Enable: Maps SDK for Android + Maps SDK for JavaScript
GOOGLE_MAPS_API_KEY=AIzaSyD_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
