# BoxDrop Backend Environment Variables
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace placeholder values with your actual API keys and credentials
# 3. Load environment: source .env
# 4. Start backend: ./gradlew run
#
# DO NOT COMMIT THIS FILE - .env is in .gitignore
# Keep this .env.example file in git with placeholder values for documentation

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=boxdrop
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ============================================
# REDIS CACHE
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# JWT AUTHENTICATION
# ============================================
# Must be at least 32 characters for production
JWT_SECRET=your-secret-key-min-32-characters-long-change-in-production

# ============================================
# AWS S3 (File Storage)
# ============================================
S3_BUCKET=boxdrop-images
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_MAX=5000
RATE_LIMIT_WINDOW=60

# ============================================
# OTP (One-Time Password)
# ============================================
OTP_EXPIRY=600

# ============================================
# RESEND (Email Service)
# ============================================
# Sign up: https://resend.com/api-keys
# Get your API key and add below
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@boxdrop.local

# ============================================
# TWILIO (SMS Service)
# ============================================
# Sign up: https://www.twilio.com/try-twilio
# Get Account SID, Auth Token, and phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ============================================
# STRIPE (Payment Processing)
# ============================================
# Sign up: https://dashboard.stripe.com/register
# Get API keys from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
